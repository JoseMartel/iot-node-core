# Build artifacts
build/
build_*_*/

# Configuration files
sdkconfig
sdkconfig.old

# Managed components (if used)
managed_components/
# dependencies.lock should generally be tracked if using idf_component_manager,
# but some sources suggest ignoring it. For a general template, it's safer to ignore
# and let the user decide to track if needed.
dependencies.lock

# Python artifacts
*.pyc
__pycache__/

