.clangd/
.ccls-cache/
.idea/
*.user
*.workspace
*.suo
*.sln
*.sublime-project
*.sublime-workspace
*.swp
*.swo

# CMake generated files
CMakeCache.txt
CMakeFiles/
Makefile

# ESP-IDF toolchain files
.espressif/

# Compiled binaries and maps
*.bin
*.elf
*.map

# Log files
*.log
app_info_*.txt
size_info_*.txt
pytest_embedded_log/
TEST_LOGS/
build_summary_*.xml

# Object files
*.o

# macOS specific
.DS_Store
.directory

# Gtags
GTAGS
GRTAGS
GPATH

